{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist/",
    "baseUrl": "./",
    "paths": {
      "#adapters/anvil": ["./src/adapters/anvil"],
      "#adapters/bugc": ["./src/adapters/bugc"],
      "#adapters/soldb": ["./src/adapters/soldb"],
      "#adapters/solc": ["./src/adapters/solc"],
      "#runner": ["./src/runner"],
      "#types": ["./src/types"]
    }
  },
  "include": ["src/**/*", "test/**/*", "*.ts"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../bugc" }, { "path": "../format" }]
}
